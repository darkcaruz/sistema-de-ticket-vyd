# ==========================================
# HELPDESK PRO - CONFIGURACIÓN DE ENTORNO
# ==========================================
# Copia este archivo como .env y completa los valores

# Servidor
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Seguridad
SESSION_SECRET=cambiar_esto_por_una_clave_secreta_muy_larga_y_aleatoria
BCRYPT_ROUNDS=12

# Base de Datos (SQLite)
DB_STORAGE=./database/helpdesk.db

# ==========================================
# CORREO SALIENTE (SMTP) - Para enviar notificaciones
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=soporte@tuempresa.com
SMTP_PASS=tu_contraseña_de_aplicacion
SMTP_FROM_NAME=Mesa de Ayuda
SMTP_FROM_EMAIL=soporte@tuempresa.com

# ==========================================
# CORREO ENTRANTE (IMAP) - Para recibir tickets
# ==========================================
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=soporte@tuempresa.com
IMAP_PASS=tu_contraseña_de_aplicacion
IMAP_MAILBOX=INBOX
IMAP_CHECK_INTERVAL=60

# ==========================================
# ARCHIVOS ADJUNTOS
# ==========================================
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,txt,zip,rar
